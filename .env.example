# Optional: use 127.0.0.1 for Metro when running on iOS Simulator (avoids simctl openurl timeout)
# REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1

# Supabase (Expo only reads vars prefixed with EXPO_PUBLIC_)
# Use the publishable key (sb_publishable_...). Never put the secret key in the app.
# Dashboard → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://shgpurjhwftjvjeyalgv.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hugging Face Inference API
# Get your token at https://huggingface.co/settings/tokens
# Required for negotiation brief generation and script writing (Llama-3.1-8B-Instruct)
HF_TOKEN=
EXPO_PUBLIC_HF_TOKEN=

# Webhook base URL for voice provider callbacks
# For Supabase Edge Functions: https://<project-ref>.supabase.co/functions/v1
WEBHOOK_BASE_URL=https://shgpurjhwftjvjeyalgv.supabase.co/functions/v1

# Twilio – Telephony for the primary local Pipecat voice pipeline
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Pipecat WebSocket URL (required for Twilio/local voice pipeline)
# Run voice-server (see voice-server/README), expose with ngrok, then set:
#   npx supabase secrets set PIPECAT_WS_URL="wss://YOUR_NGROK_URL"
# Example: wss://abc123.ngrok-free.app
PIPECAT_WS_URL=

# Bland AI – Optional cloud fallback (set provider: 'bland' in app to use)
# Get your key at https://app.bland.ai/dashboard
BLAND_AI_API_KEY=
