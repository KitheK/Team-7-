# Supabase (Expo only reads vars prefixed with EXPO_PUBLIC_)
# Use the publishable key (sb_publishable_...). Never put the secret key in the app.
# Dashboard → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://shgpurjhwftjvjeyalgv.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hugging Face Inference API
# Get your token at https://huggingface.co/settings/tokens
# Required for negotiation brief generation and script writing (Llama-3.1-8B-Instruct)
HF_TOKEN=

# Bland AI – Voice API for outbound negotiation calls (cloud fallback)
# Get your key at https://app.bland.ai/dashboard
BLAND_AI_API_KEY=

# Webhook base URL for voice provider callbacks
# For Supabase Edge Functions: https://<project-ref>.supabase.co/functions/v1
WEBHOOK_BASE_URL=https://shgpurjhwftjvjeyalgv.supabase.co/functions/v1

# Twilio – Telephony for local Pipecat voice pipeline
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Pipecat WebSocket URL (local voice server)
# Set this to enable the local pipeline. Example: wss://abc123.ngrok.io
# When set, the negotiations-start function will route calls via Twilio + Pipecat
# instead of Bland AI.
PIPECAT_WS_URL=
